using Gtk 4.0;
using Adw 1;

template $TasksPopover: Gtk.Popover {
	width-request: 350;

	child: Stack stack {
		Adw.StatusPage empty_status_page {
			styles ["compact", "menu"]
			title: _("Empty...");
			description: _("Tasks will appear here");
			icon-name: "list-large-symbolic";
		}
		ScrolledWindow scrolled_window {
			max-content-height: 750;
			ListBox list_box {
				selection-mode: none;
				styles ["boxed-list-separate"]
			}
		}
	};
}
